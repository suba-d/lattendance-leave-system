# =============================================================================
#  Required
# =============================================================================
# Supabase pooled URL (used by Next.js at runtime, goes through pgbouncer).
# Find under: Supabase project → Settings → Database → Connection string → URI
# Append `&schema=lattendance` so this app's tables are isolated from nshop.
DATABASE_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=lattendance"

# Direct (non-pooled) URL — used only by `prisma migrate deploy` at build time.
# Same Settings page → "Direct connection". Append `&schema=lattendance`.
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?schema=lattendance"

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_WITH_32_BYTES_OF_RANDOM"

# =============================================================================
#  Strongly recommended (production)
# =============================================================================
# Comma-separated allowlist of office IPs / CIDR ranges that may clock in/out.
# This is a fallback only — admin can manage the same list at runtime via
# /admin/settings (DB row takes precedence over this env value).
OFFICE_IP_ALLOWLIST=""

# Optional. Shared secret for /api/cron/cleanup-receipts. Without this set,
# the cleanup endpoint refuses every request (safer default). Wire to any
# external cron runner (cron-job.org, EventBridge, pg_cron + pg_net).
CRON_SECRET=""

# Trust X-Forwarded-For (Amplify / Cloudflare put real client IP here).
TRUST_PROXY="true"

# =============================================================================
#  Defaults — override only if needed
# =============================================================================
TZ="Asia/Taipei"
WORK_START_HOUR="9"
WORK_END_HOUR="18"

# Initial admin user (used by `pnpm db:seed` on first deploy).
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="管理員"

# =============================================================================
#  Optional integrations
# =============================================================================
# --- Google Calendar (shared company calendar via Service Account) ---
# GOOGLE_CALENDAR_ID="abc123@group.calendar.google.com"
# GOOGLE_SERVICE_ACCOUNT_EMAIL="svc@<gcp-project>.iam.gserviceaccount.com"
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Public app URL — required for LINE callbacks / invite links ---
# APP_URL="https://attendance.example.com"

# --- LINE Messaging API (push + webhook) ---
# Settings → Channel → Messaging API
# LINE_CHANNEL_ACCESS_TOKEN=""
# LINE_CHANNEL_SECRET=""
# Optional override; if blank, the bot auto-binds when admin types `/bind`
# in a group/room/DM, and stores the target in the DB.
# LINE_TARGET_ID=""

# --- LINE Login (OAuth) — same channel works if both products are enabled ---
# LINE_LOGIN_CHANNEL_ID=""
# LINE_LOGIN_CHANNEL_SECRET=""

# --- LIFF ---
# Public ID (exposed to browser) — created in LINE Developers → LIFF.
# NEXT_PUBLIC_LIFF_ID=""
