# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lattendance?schema=public"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Optional in dev. In production set to canonical URL.
# AUTH_URL="https://attendance.example.com"

# --- Office IP allowlist ---
# Comma-separated list of IPs / CIDR ranges that are permitted to clock in/out.
# Example: "203.0.113.10,198.51.100.0/24"
# Leave blank to disable IP enforcement (NOT recommended in production).
OFFICE_IP_ALLOWLIST=""
# When true, trust the X-Forwarded-For header (set this when behind a proxy /
# Vercel / Cloudflare). When false, falls back to the connection remote address.
TRUST_PROXY="true"

# --- Office hours / timezone ---
TZ="Asia/Taipei"
WORK_START_HOUR="9"
WORK_END_HOUR="18"

# --- Initial admin (used by db:seed) ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="Admin"

# --- Google Calendar (optional, env-gated) ---
# Create a Service Account, share a company calendar with it, then fill these.
# GOOGLE_CALENDAR_ID="abc123@group.calendar.google.com"
# GOOGLE_SERVICE_ACCOUNT_EMAIL="svc@my-project.iam.gserviceaccount.com"
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- LINE Messaging API (optional, env-gated) ---
# Create a Messaging API channel, invite the bot to your group, capture
# the groupId via webhook, then fill these.
# LINE_CHANNEL_ACCESS_TOKEN=""
# LINE_TARGET_ID=""  # group ID, room ID, or user ID
